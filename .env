# Hyperliquid environment: mainnet or testnet
HYPERLIQUID_ENV=mainnet

# Wallet utama yang kamu connect ke Hyperliquid
HYPERLIQUID_ACCOUNT_ADDRESS=0xYOUR_MASTER_WALLET_ADDRESS

# Agent/API wallet address dari Hyperliquid
HYPERLIQUID_AGENT_WALLET_ADDRESS=0xYOUR_AGENT_WALLET_ADDRESS

# Private key agent/API wallet. Ganti hanya di file lokal kamu.
HYPERLIQUID_PRIVATE_KEY=YOUR_AGENT_PRIVATE_KEY

# Trading rules
STARTING_CAPITAL_USD=10
LEVERAGE=10
MARGIN_PER_TRADE_USD=2
MAX_POSITION_VALUE_USD=20
MAX_STOP_LOSS_PCT=0.5
MIN_TAKE_PROFIT_PCT=1.2
MIN_RISK_REWARD=2
MAX_DAILY_LOSS_USD=0.5
MAX_TRADES_PER_DAY=3
MAX_CONSECUTIVE_LOSSES=2
MAX_OPEN_POSITIONS=1
MIN_SIGNAL_SCORE=80
COOLDOWN_AFTER_LOSS_MINUTES=30
ALLOWED_MARKETS=BTC,ETH,SOL,HYPE
